---
const textLinks: { label: string; href: string }[] = [
	{ label: 'Home', href: '/' },
	{ label: 'Blog', href: '/blog/' },
	{ label: 'Projects', href: '/projects/' },
	{ label: 'Open Source', href: '/open-source/' },
	{ label: 'Uses', href: '/uses/' },
];
---

<nav>
	<header class="relative px-4 sm:px-6 md:px-8 xl:px-12 pt-6">
		<div class="flex items-center text-center flex-col sm:flex-row gap-4 md:gap-0">
			<a href="/" class="border-none text-sm font-bold tracking-[0.02em] text-indigo-600" transition:persist>
				Jyrki De Neve
			</a>
			<div class="relative flex items-center sm:ml-auto">
				<nav>
					<ul class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 leading-none">
						{
							textLinks.map(({ label, href }) => {
								const isActive =
									Astro.url.pathname === href ||
									(href !== '/' && Astro.url.pathname.startsWith(href));
								return (
									<li>
										<a
											aria-current={isActive}
											class:list={[
												'whitespace-pre',
												'uppercase',
												'text-[11px]',
												'tracking-[0.14em]',
												isActive ? 'text-indigo-600' : 'text-ink/55',
											]}
											href={href}
										>
											{isActive ? '> ' : '  '}{label}
										</a>
									</li>
								);
							})
						}
					</ul>
				</nav>
			</div>
		</div>
	</header>
</nav>
