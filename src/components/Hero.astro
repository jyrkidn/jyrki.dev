---
interface Props {
	title: string;
	tagline?: string;
	align?: 'start' | 'center';
	eyebrow?: string;
	divider?: boolean;
}

const { align = 'center', tagline, title, eyebrow, divider = false } = Astro.props;
---

<div class="text-md md:text-lg md:leading-8">
	{eyebrow && (
		<div class="text-[11px] tracking-[0.32em] text-indigo-600/65 mb-6 uppercase">
			── {eyebrow} ──
		</div>
	)}
	<h1 class="text-xl md:text-2xl font-extrabold text-indigo-600">
		{title}
	</h1>
	{tagline && <p class="mt-5">{tagline}</p>}
	{divider && (
		<div
			class="mt-14 text-[11px] text-indigo-600/40 tracking-[2px] font-mono select-none"
			aria-hidden="true"
		>
			▚▚▚▞▞▞ ░░▒▒▓▓█ ▞▞▞▚▚▚
		</div>
	)}
</div>
